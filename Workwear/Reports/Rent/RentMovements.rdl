<?xml version="1.0" encoding="UTF-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2005/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <Description></Description>
  <Author></Author>
  <PageHeight>8.5in</PageHeight>
  <PageWidth>11in</PageWidth>
  <DataSources>
    <DataSource Name="DS1">
      <ConnectionProperties>
        <DataProvider>MySqlConnector</DataProvider>
        <ConnectString>server=atlas.srv.qsolution.ru;user=SpMob;database=specposhiv_kos;port=3306;password=QlZEal1FlwZuKFc5</ConnectString>
      </ConnectionProperties>
    </DataSource>
  </DataSources>
  <Width>7.5in</Width>
  <TopMargin>.25in</TopMargin>
  <LeftMargin>.25in</LeftMargin>
  <RightMargin>.25in</RightMargin>
  <BottomMargin>.25in</BottomMargin>
  <ReportParameters>
    <ReportParameter Name="period_begin">
      <DataType>String</DataType>
      <Nullable>False</Nullable>
      <DefaultValue>
        <Values>
          <Value>2026-03-01</Value>
        </Values>
      </DefaultValue>
      <AllowBlank>False</AllowBlank>
    </ReportParameter>
    <ReportParameter Name="period_end">
      <DataType>String</DataType>
      <Nullable>False</Nullable>
      <DefaultValue>
        <Values>
          <Value>2026-03-31</Value>
        </Values>
      </DefaultValue>
      <AllowBlank>False</AllowBlank>
    </ReportParameter>
    <ReportParameter Name="nomenclature_ids">
      <DataType>Integer</DataType>
      <Nullable>False</Nullable>
      <DefaultValue>
        <Values>
          <Value>-1</Value>
        </Values>
      </DefaultValue>
      <AllowBlank>False</AllowBlank>
    </ReportParameter>
  </ReportParameters>
  <DataSets>
    <DataSet Name="Data">
      <Query>
        <DataSourceName>DS1</DataSourceName>
        <CommandText>SELECT 
    iswo.nomenclature_id,
    n.name AS nomenclature_name,
    n.rent_cost_day AS day_cost,
    
    #Количество числится в начале периода
    SUM(IF(iswo.operation_time &lt;= @period_begin, iswo.issued - iswo.returned_before_period, 0)) AS count_at_period_start,
    
    #Количество числится в конце периода
    SUM(IF(iswo.operation_time &lt; @period_end, iswo.issued - iswo.returned_during_period - iswo.returned_before_period, 0)) AS count_at_period_end,
    
    #Количество вещей числящихся полный период
    SUM(IF(iswo.operation_time &lt;= @period_begin AND iswo.auto_writeoff_date &gt; @period_end AND iswo.returned_during_period = 0,
           iswo.issued - iswo.returned_before_period, 0)) AS items_full_period,
        
    #Дней носки для полных периодов
    SUM(IF(iswo.operation_time &lt;= @period_begin AND iswo.auto_writeoff_date &gt; @period_end AND iswo.returned_during_period = 0,
           (iswo.issued - iswo.returned_before_period) * DATEDIFF(@period_end, @period_begin), 0)) AS days_full_period,
    
    #Выданное за период
    SUM(IF(iswo.operation_time &gt;= @period_begin AND iswo.operation_time &lt; @period_end, iswo.issued, 0)) AS issued,
    
    #Списанное за период
    SUM(iswo.returned_during_period) AS returned,

    #Числившееся не полный период
    SUM(IF((iswo.operation_time BETWEEN @period_begin AND @period_end) OR (iswo.returned_during_period &gt; 0),
           iswo.issued - iswo.returned_during_period - iswo.returned_before_period, 0)) AS items_partial_period,
    
    #Дней носки с неполного периода
    #Работает с полными списаниями или выдачами по 1, на большом периоде или при частичных списаниях будут неточности
    SUM(IF((iswo.operation_time BETWEEN @period_begin AND @period_end) OR (iswo.returned_during_period &gt; 0),
        (iswo.issued - iswo.returned_during_period - iswo.returned_before_period) * DATEDIFF(
            LEAST(@period_end, iswo.writeoff_date),
            GREATEST(iswo.operation_time, @period_begin)), 0)) AS days_partial_period,

    #Общее количество дней
    SUM(IF(iswo.operation_time &lt;= @period_begin AND iswo.auto_writeoff_date &gt; @period_end AND iswo.returned_during_period = 0,
           (iswo.issued - iswo.returned_before_period) * DATEDIFF(@period_end, @period_begin), 0))
    +
    SUM(IF((iswo.operation_time BETWEEN @period_begin AND @period_end) OR (iswo.returned_during_period &gt; 0),
           (iswo.issued - iswo.returned_during_period - iswo.returned_before_period) * DATEDIFF(
                   LEAST(@period_end, iswo.writeoff_date),
                   GREATEST(iswo.operation_time, @period_begin)), 0)) AS total_days_used,
    
    #Стоимость за период
    (SUM(IF(iswo.operation_time &lt;= @period_begin AND iswo.auto_writeoff_date &gt; @period_end AND iswo.returned_during_period = 0,
            (iswo.issued - iswo.returned_before_period) * DATEDIFF(@period_end, @period_begin), 0))
        +
     SUM(IF((iswo.operation_time BETWEEN @period_begin AND @period_end) OR (iswo.returned_during_period &gt; 0),
            (iswo.issued - iswo.returned_during_period - iswo.returned_before_period) * DATEDIFF(
                    LEAST(@period_end, iswo.writeoff_date),
                    GREATEST(iswo.operation_time, @period_begin)), 0))) * COALESCE(n.rent_cost_day, 0) AS period_cost

FROM (SELECT
             issue.id,
             issue.nomenclature_id,
             issue.operation_time,
             issue.issued,
             issue.auto_writeoff_date,
             COALESCE(SUM(write_off.returned), 0) AS total_written_off,
             COALESCE(MAX(write_off.operation_time), NULL) AS writeoff_date, #Множественное списание, пока не поддерживаем
             COALESCE(SUM(IF(write_off.operation_time &gt;= @period_begin AND write_off.operation_time &lt;= @period_end, write_off.returned, 0)), 0) AS returned_during_period,
             COALESCE(SUM(IF(write_off.operation_time &lt; @period_begin, write_off.returned, 0)), 0) AS returned_before_period
         FROM operation_issued_by_employee issue
                  LEFT JOIN operation_issued_by_employee write_off
                            ON write_off.issued_operation_id = issue.id AND write_off.returned &gt; 0
         WHERE issue.returned = 0
           AND issue.operation_time &lt; @period_end
           AND (issue.auto_writeoff_date &gt; @period_begin OR issue.auto_writeoff_date IS NULL)
           AND ((-1 IN (@nomenclature_ids)) OR issue.nomenclature_id IN (@nomenclature_ids))
         GROUP BY issue.id
     ) iswo
JOIN nomenclature n ON iswo.nomenclature_id = n.id
WHERE n.archival = 0 
  AND (iswo.total_written_off &lt; iswo.issued OR iswo.writeoff_date &lt;= @period_end)
GROUP BY iswo.nomenclature_id, n.name, n.rent_cost_day
ORDER BY n.name</CommandText>
        <QueryParameters>
          <QueryParameter Name="period_begin">
            <Value>=Parameters!period_begin</Value>
          </QueryParameter>
          <QueryParameter Name="period_end">
            <Value>=Parameters!period_end</Value>
          </QueryParameter>
          <QueryParameter Name="nomenclature_ids">
            <Value>=Parameters!nomenclature_ids</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
      <Fields>
        <Field Name="nomenclature_id">
          <DataField>nomenclature_id</DataField>
          <rd:TypeName>System.UInt32</rd:TypeName>
        </Field>
        <Field Name="nomenclature_name">
          <DataField>nomenclature_name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="day_cost">
          <DataField>day_cost</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="count_at_period_start">
          <DataField>count_at_period_start</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="count_at_period_end">
          <DataField>count_at_period_end</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="items_full_period">
          <DataField>items_full_period</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="days_full_period">
          <DataField>days_full_period</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="issued">
          <DataField>issued</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="returned">
          <DataField>returned</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="items_partial_period">
          <DataField>items_partial_period</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="days_partial_period">
          <DataField>days_partial_period</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="total_days_used">
          <DataField>total_days_used</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="period_cost">
          <DataField>period_cost</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
