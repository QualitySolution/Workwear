        <Height>20pt</Height>
        <Width>450pt</Width>
        <Value>Форма акта об оказанных услугах</Value>
        <ZIndex>1</ZIndex>
        <Left>130pt</Left>
        <Top>3pt</Top>
        <Style>
          <FontWeight>Bold</FontWeight>
          <FontSize>12pt</FontSize>
          <TextAlign>Center</TextAlign>
        </Style>
      </Textbox>
      <Textbox Name="ActNumber">
