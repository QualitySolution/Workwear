          <FontSize>10pt</FontSize>
        </Style>
      </Textbox>
      <Textbox Name="ActDate">
        <Height>14pt</Height>
        <Width>200pt</Width>
        <Value>от {?act_date:D}</Value>
        <ZIndex>3</ZIndex>
        <Left>10pt</Left>
        <Top>46pt</Top>
