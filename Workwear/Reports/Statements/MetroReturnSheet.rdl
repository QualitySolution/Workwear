  <DataElementName>Report</DataElementName>
  <DataElementStyle>AttributeNormal</DataElementStyle>
  <DataSets>
    <DataSet Name="Data">
      <Query >
        <DataSourceName>DS1</DataSourceName>
        <CommandText>SELECT
    employees.last_name,
    employees.first_name,
    employees.patronymic_name,
    employees.personnel_number,
    nomenclature.name as nomenclature_name,
    measurement_units.name as units,
    COALESCE(this_issuse.returned, this_duty_issued.returned) as amount_return
FROM stock_return_items
         LEFT JOIN stock_return ON stock_return.id = stock_return_items.stock_return_id
         LEFT JOIN employees ON employees.id = stock_return_items.employee_id
         LEFT JOIN nomenclature on nomenclature.id = stock_return_items.nomenclature_id
         LEFT JOIN operation_issued_by_employee as this_issuse on this_issuse.id = stock_return_items.employee_issue_operation_id
         LEFT JOIN operation_issued_by_duty_norm as this_duty_issued ON this_duty_issued.id = stock_return_items.duty_norm_issue_operation_id
         LEFT JOIN item_types ON nomenclature.type_id = item_types.id
         LEFT JOIN measurement_units ON item_types.units_id = measurement_units.id
WHERE stock_return_items.stock_return_id = @id</CommandText>
        <QueryParameters>
          <QueryParameter Name="id">
            <Value>={?id}</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
      <Fields >
        <Field Name="last_name">
          <DataField>last_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="first_name">
          <DataField>first_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="patronymic_name">
          <DataField>patronymic_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="personnel_number">
          <DataField>personnel_number</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="nomenclature_name">
          <DataField>nomenclature_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="units">
          <DataField>units</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="amount_return">
          <DataField>amount_return</DataField>
          <TypeName>System.Int32</TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Sheet">
      <Query >
        <DataSourceName>DS1</DataSourceName>
        <CommandText>SELECT
    IFNULL(stock_return.doc_number, stock_return.id) as doc_number,
    stock_return.date AS doc_date,
    CONCAT_WS(', ', 'ГУП Петербургский метрополитен', GROUP_CONCAT(distinct subdivisions.name)) as organization_from,
    'ООО Метрохим' as organization_to,
    '' as transfer_from,
    '' as transfer_to,
    '20.03.2026' as contract_date,
    '0001239' as contract_number,
    '' as responsible_person_post,
    '' as responsible_person_name,
    '' as transfer_agent_fio,
    '' AS transfer_agent_post
FROM stock_return
    LEFT JOIN stock_return_items ON stock_return.id = stock_return_items.stock_return_id
    LEFT JOIN employees ON stock_return_items.employee_id = employees.id
    LEFT JOIN subdivisions ON employees.subdivision_id = subdivisions.id
WHERE stock_return.id = @id
GROUP BY stock_return.id</CommandText>
        <QueryParameters>
          <QueryParameter Name="id">
            <Value>={?id}</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
      <Fields >
        <Field Name="doc_number">
          <DataField>doc_number</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="doc_date">
          <DataField>doc_date</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="organization_from">
          <DataField>organization_from</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="organization_to">
          <DataField>organization_to</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="transfer_from">
          <DataField>transfer_from</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="transfer_to">
          <DataField>transfer_to</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="contract_date">
          <DataField>contract_date</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="contract_number">
          <DataField>contract_number</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="responsible_person_post">
          <DataField>responsible_person_post</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="responsible_person_name">
          <DataField>responsible_person_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="transfer_agent_fio">
          <DataField>transfer_agent_fio</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="transfer_agent_post">
          <DataField>transfer_agent_post</DataField>
          <TypeName>System.String</TypeName>
        </Field>
      </Fields>
    </DataSet>
