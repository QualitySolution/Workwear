  <DataElementName>Report</DataElementName>
  <DataElementStyle>AttributeNormal</DataElementStyle>
  <DataSets>
    <DataSet Name="Data">
      <Query>
        <DataSourceName>DS1</DataSourceName>
        <CommandText>SELECT
    employees.id as employee_id,
    employees.last_name,
    employees.first_name,
    employees.patronymic_name,
    employees.personnel_number,
    IFNULL(nomenclature.name, protection_tools.name) as nomenclature,
    sizeAlias.name as size,
    heightAlias.name as growth,
    nomenclature.number as nomenclature_number,
    measurement_units.name as units,
    measurement_units.okei,
    issuance_sheet_items.amount,
    issuance_sheet_items.start_of_use,
    issuance_sheet_items.lifetime
FROM
    issuance_sheet_items
        LEFT JOIN operation_issued_by_employee on operation_issued_by_employee.id = issuance_sheet_items.issued_operation_id
        LEFT JOIN employees ON employees.id = issuance_sheet_items.employee_id
        LEFT JOIN nomenclature ON issuance_sheet_items.nomenclature_id = nomenclature.id
        LEFT JOIN protection_tools ON protection_tools.id = issuance_sheet_items.protection_tools_id
        LEFT JOIN item_types ON (nomenclature.type_id = item_types.id OR protection_tools.item_types_id = item_types.id)
        LEFT JOIN measurement_units ON item_types.units_id = measurement_units.id
        LEFT JOIN sizes AS sizeAlias ON sizeAlias.id = issuance_sheet_items.size_id
        LEFT JOIN sizes AS heightAlias ON heightAlias.id = issuance_sheet_items.height_id
WHERE
        issuance_sheet_items.issuance_sheet_id = @id
ORDER BY employees.last_name, employees.first_name, employees.patronymic_name</CommandText>
        <QueryParameters>
          <QueryParameter Name="id">
            <Value>={?id}</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
      <Fields>
        <Field Name="last_name">
          <DataField>last_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="first_name">
          <DataField>first_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="patronymic_name">
          <DataField>patronymic_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="personnel_number">
          <DataField>personnel_number</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="nomenclature">
          <DataField>nomenclature</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="size">
          <DataField>size</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="growth">
          <DataField>growth</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="nomenclature_number">
          <DataField>nomenclature_number</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="units">
          <DataField>units</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="okei">
          <DataField>okei</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="amount">
          <DataField>amount</DataField>
          <TypeName>System.UInt16</TypeName>
        </Field>
        <Field Name="start_of_use">
          <DataField>start_of_use</DataField>
          <TypeName>System.DateTime</TypeName>
        </Field>
        <Field Name="lifetime">
          <DataField>lifetime</DataField>
          <TypeName>System.Decimal</TypeName>
        </Field>
        <Field Name="employee_id">
          <DataField>employee_id</DataField>
          <TypeName>System.Int32</TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Sheet">
      <Query>
        <DataSourceName>DS1</DataSourceName>
        <CommandText>SELECT
    IFNULL(issuance_sheet.doc_number, issuance_sheet.id)
                                                                                                       as doc_number,
    issuance_sheet.date,
    organizations.name as organization,
    organizations.okpo as okpo,
    subdivisions.name as subdivision,
    subdivisions.code as subdivision_code,
    CONCAT_WS('',
              CONCAT(responsible_person.surname, ' '),
              IF(responsible_person.name = '',
                 '',
                 CONCAT(LEFT(responsible_person.name, 1), '.')),
              IF(responsible_person.patronymic = '',
                 '',
                 CONCAT(LEFT(responsible_person.patronymic, 1), '.'))) as responsible_person_name,
    responsible_person.position as responsible_person_post,
    CONCAT_WS('',
              CONCAT(head_of_division.surname, ' '),
              IF(head_of_division.name = '',
                 '',
                 CONCAT(LEFT(head_of_division.name, 1), '.')),
              IF(head_of_division.patronymic = '',
                 '',
                 CONCAT(LEFT(head_of_division.patronymic, 1), '.'))) as head_of_division_name,
    head_of_division.position as head_of_division_post,
    CONCAT_WS(" ", transfer_agent.last_name,transfer_agent.first_name, transfer_agent.patronymic_name) as transfer_agent_fio,
    transfer_agent_post.name AS transfer_agent_post
FROM
    issuance_sheet
        LEFT JOIN organizations ON organizations.id = issuance_sheet.organization_id
        LEFT JOIN subdivisions ON subdivisions.id = issuance_sheet.subdivision_id
        LEFT JOIN leaders as responsible_person ON responsible_person.id = issuance_sheet.responsible_person_id
        LEFT JOIN leaders as head_of_division ON head_of_division.id = issuance_sheet.head_of_division_person_id
        LEFT JOIN employees as transfer_agent on transfer_agent.id = issuance_sheet.transfer_agent_id
        LEFT JOIN posts as transfer_agent_post on transfer_agent_post.id = transfer_agent.post_id
WHERE
        issuance_sheet.id = @id</CommandText>
        <QueryParameters>
          <QueryParameter Name="id">
            <Value>={?id}</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
      <Fields>
        <Field Name="doc_number">
          <DataField>doc_number</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="date">
          <DataField>date</DataField>
          <TypeName>System.DateTime</TypeName>
        </Field>
        <Field Name="organization">
          <DataField>organization</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="subdivision">
          <DataField>subdivision</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="subdivision_code">
          <DataField>subdivision_code</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="responsible_person_name">
          <DataField>responsible_person_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="responsible_person_post">
          <DataField>responsible_person_post</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="head_of_division_name">
          <DataField>head_of_division_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="head_of_division_post">
          <DataField>head_of_division_post</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="transfer_agent_fio">
          <DataField>transfer_agent_fio</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="transfer_agent_post">
          <DataField>transfer_agent_post</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="okpo">
          <DataField>okpo</DataField>
          <TypeName>System.String</TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
