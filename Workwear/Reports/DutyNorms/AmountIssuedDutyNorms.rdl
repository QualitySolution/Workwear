          <TypeName>System.Int32</TypeName>
        </Field>
        <Field Name="article">
          <DataField>article</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="size">
          <DataField>size</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="growth">
          <DataField>growth</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="owner_name">
          <DataField>owner_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="cost">
          <DataField>cost</DataField>
          <TypeName>System.Decimal</TypeName>
        </Field>
        <Field Name="cost_sum">
          <DataField>cost_sum</DataField>
          <TypeName>System.Decimal</TypeName>
        </Field>
        <Field Name="wearing_period">
          <DataField>wearing_period</DataField>
          <TypeName>System.UInt32</TypeName>
        </Field>
        <Field Name="operation_date">
          <DataField>operation_date</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="issuance_sheet">
          <DataField>issuance_sheet</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="employee">
          <DataField>employee</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="personnel_number">
          <DataField>personnel_number</DataField>
          <TypeName>System.String</TypeName>
