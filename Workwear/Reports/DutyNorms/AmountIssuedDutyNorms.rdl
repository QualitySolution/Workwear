  <DataElementName>Report</DataElementName>
  <DataElementStyle>AttributeNormal</DataElementStyle>
  <DataSets>
    <DataSet Name="Data">
      <Query>
        <DataSourceName>DS1</DataSourceName>
        <CommandText>SELECT
    subdivisions.id as subdivision_id,
    subdivisions.code as subdivision_code,
    subdivisions.name as subdivision,
    duty_norms.name as duty_norm_name,
    nomenclature.name as nomenclature,
    operation_issued_by_duty_norm.issued as amount,
    nomenclature.number as article,
    if(@alternativeName, IFNULL(sizeAlias.alternative_name, sizeAlias.name), sizeAlias.name) as size,
    heightAlias.name as growth,
    if(@showOwners, owners.name, null) as owner_name,
    nomenclature.sale_cost AS cost,
    operation_issued_by_duty_norm.issued * nomenclature.sale_cost AS cost_sum,
    CASE duty_norm_items.period_type
        WHEN 'Year' THEN duty_norm_items.period_count * 12
        WHEN 'Month' THEN duty_norm_items.period_count
        END AS wearing_period,
    DATE_FORMAT(operation_issued_by_duty_norm.operation_time, '%d.%m.%Y') as operation_date,
    IFNULL(issuance_sheet.doc_number, issuance_sheet.id) as issuance_sheet,
    CONCAT_WS(' ', employees.last_name, employees.first_name, employees.patronymic_name) AS employee,
    employees.personnel_number AS personnel_number,
    posts.name AS post,
    IFNULL(stock_expense_duty_norm.doc_number, stock_expense_duty_norm.id) AS doc_number,
    stock_expense_duty_norm.comment AS document_comment,
    operation_issued_by_duty_norm.comment AS operation_comment
FROM operation_issued_by_duty_norm
     LEFT JOIN duty_norms on operation_issued_by_duty_norm.duty_norm_id = duty_norms.id
     LEFT JOIN duty_norm_items on duty_norms.id = duty_norm_items.duty_norm_id
     LEFT JOIN stock_expense_duty_norm_items on operation_issued_by_duty_norm.id = stock_expense_duty_norm_items.operation_issued_by_duty_norm_id
     LEFT JOIN stock_expense_duty_norm on stock_expense_duty_norm_items.stock_expense_duty_norm_id = stock_expense_duty_norm.id
     LEFT JOIN issuance_sheet_items ON issuance_sheet_items.issued_operation_id = operation_issued_by_duty_norm.id
     LEFT JOIN issuance_sheet ON issuance_sheet_items.duty_norm_issue_operation_id = issuance_sheet.id

     LEFT JOIN subdivisions on duty_norms.subdivision_id = subdivisions.id
     LEFT JOIN nomenclature on nomenclature.id = operation_issued_by_duty_norm.nomenclature_id
     LEFT JOIN sizes as sizeAlias ON (sizeAlias.id = operation_issued_by_duty_norm.size_id)
     LEFT JOIN sizes AS heightAlias ON (heightAlias.id = operation_issued_by_duty_norm.height_id)
     LEFT JOIN operation_warehouse ON operation_issued_by_duty_norm.warehouse_operation_id = operation_warehouse.id
     LEFT JOIN owners ON operation_warehouse.owner_id = owners.id
     LEFT JOIN protection_tools ON protection_tools.id = operation_issued_by_duty_norm.protection_tools_id

     LEFT JOIN employees on employees.id = stock_expense_duty_norm.responsible_employee_id
     LEFT JOIN posts ON posts.id = employees.post_id

WHERE operation_issued_by_duty_norm.returned = 0
  AND operation_issued_by_duty_norm.operation_time &gt;= CONVERT(@dateStart, DATE)
  AND operation_issued_by_duty_norm.operation_time &lt; DATE_ADD(CONVERT(@dateEnd, DATE), INTERVAL 1 DAY)
  AND ((-1 IN (@subdivisions)) OR (@withoutsub AND subdivisions.id IS NULL) OR (subdivisions.id IN (@subdivisions)))
  AND (@matchString IS NULL OR @matchString = '' OR duty_norms.name LIKE CONCAT('%', @matchString, '%'))
  AND (@noMatchString IS NULL OR @noMatchString = '' OR duty_norms.name NOT LIKE CONCAT('%', @noMatchString, '%'))
  AND (@allOwners OR (@withoutOwner AND owners.id IS NULL) OR owners.id = @ownerId)
ORDER BY subdivision_code, duty_norm_name, nomenclature, size, growth</CommandText>
        <QueryParameters>
          <QueryParameter Name="dateStart">
            <Value>={?dateStart}</Value>
          </QueryParameter>
          <QueryParameter Name="dateEnd">
            <Value>={?dateEnd}</Value>
          </QueryParameter>
          <QueryParameter Name="withoutsub">
            <Value>={?withoutsub}</Value>
          </QueryParameter>
          <QueryParameter Name="subdivisions">
            <Value>={?subdivisions}</Value>
          </QueryParameter>
          <QueryParameter Name="matchString">
            <Value>={?matchString}</Value>
          </QueryParameter>
          <QueryParameter Name="noMatchString">
            <Value>={?noMatchString}</Value>
          </QueryParameter>
          <QueryParameter Name="alternativeName">
            <Value>={?alternativeName}</Value>
          </QueryParameter>
          <QueryParameter Name="showOwners">
            <Value>={?showOwners}</Value>
          </QueryParameter>
          <QueryParameter Name="ownerId">
            <Value>={?ownerId}</Value>
          </QueryParameter>
          <QueryParameter Name="withoutOwner">
            <Value>={?withoutOwner}</Value>
          </QueryParameter>
          <QueryParameter Name="allOwners">
            <Value>={?allOwners}</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
      <Fields>
        <Field Name="subdivision_id">
          <DataField>subdivision_id</DataField>
          <TypeName>System.UInt32</TypeName>
        </Field>
        <Field Name="subdivision_code">
          <DataField>subdivision_code</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="subdivision">
          <DataField>subdivision</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="duty_norm_name">
