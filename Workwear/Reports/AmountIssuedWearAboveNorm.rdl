  <PageWidth>20in</PageWidth>
  <DataSources>
    <DataSource Name="DS1">
      <ConnectionProperties>
        <DataProvider>MySqlConnector</DataProvider>
        <ConnectString>server=plutus.srv.qsolution.ru;</ConnectString>
      </ConnectionProperties>
    </DataSource>
