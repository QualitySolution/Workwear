  <Width>7.5in</Width>
  <TopMargin>.25in</TopMargin>
  <LeftMargin>.25in</LeftMargin>
  <RightMargin>.25in</RightMargin>
  <BottomMargin>.25in</BottomMargin>
  <DataSets>
    <DataSet Name="Data">
      <Query >
        <DataSourceName>DS1</DataSourceName>
        <CommandText>SELECT
    objects.name as 'object_name',
    departments.name as 'department_name',
    posts.name as 'post',
    wear_cards.personnel_number as 'tab',
    CONCAT_WS(' ' ,wear_cards.last_name, wear_cards.first_name, wear_cards.patronymic_name) as 'wear_card_name',
    IF(wear_cards.dismiss_date BETWEEN @start_date AND ADDDATE(@end_date,1),
       DATE_FORMAT(wear_cards.dismiss_date, '%d.%m.%Y'), NULL) as 'dismiss_date',
    operation_issued_by_employee.id as 'op_id',
    protection_tools.name as 'protection_tool',
    nomenclature.name as 'nomenclature',
    DATE_FORMAT(operation_issued_by_employee.operation_time, '%d.%m.%Y') as 'operation_time',
    operation_issued_by_employee.issued as 'amount',
    nomenclature.sale_cost,
    operation_issued_by_employee.comment
FROM operation_issued_by_employee
         LEFT JOIN protection_tools on operation_issued_by_employee.protection_tools_id = protection_tools.id
         LEFT JOIN nomenclature on operation_issued_by_employee.nomenclature_id = nomenclature.id
         LEFT JOIN wear_cards on operation_issued_by_employee.employee_id = wear_cards.id
         LEFT JOIN posts on posts.id = wear_cards.post_id
         LEFT JOIN objects on objects.id = wear_cards.object_id
         LEFT JOIN departments on departments.id = wear_cards.department_id

         LEFT JOIN wear_cards_item on (wear_cards_item.wear_card_id = operation_issued_by_employee.employee_id
    AND wear_cards_item.norm_item_id = operation_issued_by_employee.norm_item_id)
WHERE wear_cards.dismiss_date is null
  AND wear_cards_item.id is null
  AND operation_issued_by_employee.auto_writeoff_date &gt; NOW()
ORDER BY object_name,department_name,post, wear_card_name, protection_tool;</CommandText>
        <QueryParameters>
          <QueryParameter Name="start_date">
            <Value>={?start_date}</Value>
          </QueryParameter>
          <QueryParameter Name="end_date">
            <Value>={?end_date}</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
      <Fields >
        <Field Name="object_name">
          <DataField>object_name</DataField>
